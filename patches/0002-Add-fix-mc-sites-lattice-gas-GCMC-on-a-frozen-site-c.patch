+/* ---------------------------------------------------------------------- */
+
+FixMCSites::FixMCSites(LAMMPS *lmp, int narg, char **arg) :
+    Fix(lmp, narg, arg), temp_var_name(nullptr), mu_var_name(nullptr), idsites_compute(nullptr),
+    sites_compute(nullptr), sites_file(nullptr), file_xyz(nullptr), idregion(nullptr),
+    region(nullptr), random_equal(nullptr), random_unequal(nullptr), c_pe(nullptr),
+    grace_energy_only(nullptr), sublo(nullptr), subhi(nullptr), exchbuf(nullptr),
+    catalog(nullptr)
+{
+  if (narg < 8) utils::missing_cmd_args(FLERR, "fix mc/sites", error);
+
+  mcs_nevery = utils::inumeric(FLERR, arg[3], false, lmp);
+  ntrials = utils::inumeric(FLERR, arg[4], false, lmp);
+  mcs_type = utils::expand_type_int(FLERR, arg[5], Atom::ATOM, lmp);
+  seed = utils::inumeric(FLERR, arg[6], false, lmp);
+
+  if (mcs_nevery <= 0) error->all(FLERR, "Fix mc/sites Nevery must be > 0, got {}", mcs_nevery);
+  if (ntrials < 0) error->all(FLERR, "Fix mc/sites Ntrials must be >= 0, got {}", ntrials);
+  if (seed <= 0) error->all(FLERR, "Fix mc/sites seed must be > 0, got {}", seed);
+
+  temp = 0.0;
+  temp_var = -1;
+  if (utils::strmatch(arg[7], "^v_")) {
+    temp_var_name = utils::strdup(arg[7] + 2);
+  } else {
+    temp = utils::numeric(FLERR, arg[7], false, lmp);
+    if (temp <= 0.0) error->all(FLERR, "Fix mc/sites temperature must be > 0.0, got {}", temp);
+  }
+
+  // defaults
+
+  mode = MODE_GC;
+  mu = 0.0;
+  mu_var = -1;
+  rate = 0;
+  tfac_insert = 1.0;
+  charge_val = 0.0;
+  charge_flag = 0;
+  maxspecies = -1;
+  overlap_cutoff = 0.0;
+  nfile_sites = 0;
+
+  int mode_set = 0, sites_set = 0;
+
+  int iarg = 8;
+  while (iarg < narg) {
+    if (strcmp(arg[iarg], "sites") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites sites", error);
+      if (utils::strmatch(arg[iarg + 1], "^c_")) {
+        delete[] idsites_compute;
+        idsites_compute = utils::strdup(arg[iarg + 1] + 2);
+        iarg += 2;
+      } else if (strcmp(arg[iarg + 1], "file") == 0) {
+        if (iarg + 3 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites sites file", error);
+        delete[] sites_file;
+        sites_file = utils::strdup(arg[iarg + 2]);
+        iarg += 3;
+      } else
+        error->all(FLERR, "Fix mc/sites sites argument must be c_ID or file <path>, got {}",
+                   arg[iarg + 1]);
+      sites_set = 1;
+    } else if (strcmp(arg[iarg], "mode") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites mode", error);
+      if (strcmp(arg[iarg + 1], "gc") == 0) {
+        if (iarg + 4 > narg || strcmp(arg[iarg + 2], "mu") != 0)
+          error->all(FLERR, "Fix mc/sites mode gc requires: mode gc mu <value>");
+        if (utils::strmatch(arg[iarg + 3], "^v_"))
+          mu_var_name = utils::strdup(arg[iarg + 3] + 2);
+        else
+          mu = utils::numeric(FLERR, arg[iarg + 3], false, lmp);
+        mode = MODE_GC;
+        iarg += 4;
+      } else if (strcmp(arg[iarg + 1], "source") == 0) {
+        if (iarg + 4 > narg || strcmp(arg[iarg + 2], "rate") != 0)
+          error->all(FLERR, "Fix mc/sites mode source requires: mode source rate <n>");
+        rate = utils::inumeric(FLERR, arg[iarg + 3], false, lmp);
+        if (rate <= 0) error->all(FLERR, "Fix mc/sites source rate must be > 0, got {}", rate);
+        mode = MODE_SOURCE;
+        iarg += 4;
+      } else
+        error->all(FLERR, "Unknown fix mc/sites mode: {}", arg[iarg + 1]);
+      mode_set = 1;
+    } else if (strcmp(arg[iarg], "region") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites region", error);
+      delete[] idregion;
+      idregion = utils::strdup(arg[iarg + 1]);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "tfac_insert") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites tfac_insert", error);
+      tfac_insert = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      if (tfac_insert <= 0.0)
+        error->all(FLERR, "Fix mc/sites tfac_insert must be > 0.0, got {}", tfac_insert);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "charge") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites charge", error);
+      charge_val = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      charge_flag = 1;
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "maxspecies") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites maxspecies", error);
+      maxspecies = utils::bnumeric(FLERR, arg[iarg + 1], false, lmp);
+      if (maxspecies < 0)
+        error->all(FLERR, "Fix mc/sites maxspecies must be >= 0, got {}", maxspecies);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "overlap_cutoff") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "fix mc/sites overlap_cutoff", error);
+      overlap_cutoff = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      if (overlap_cutoff < 0.0)
+        error->all(FLERR, "Fix mc/sites overlap_cutoff must be >= 0.0, got {}", overlap_cutoff);
+      iarg += 2;
+    } else
+      error->all(FLERR, "Unknown fix mc/sites keyword: {}", arg[iarg]);
+  }
+
+  if (!sites_set)
+    error->all(FLERR, "Fix mc/sites requires the sites keyword (sites c_ID or sites file <path>)");
+  if (!mode_set) error->all(FLERR, "Fix mc/sites requires the mode keyword (gc or source)");
+
+  // output vector: attempts, accepted insertions, accepted deletions,
+  // N_species, catalogue size M, c = N/M, acceptance ratio, source skips
+
+  vector_flag = 1;
+  size_vector = 8;
+  global_freq = 1;
+  extvector = 0;
+  restart_global = 1;
+
+  random_equal = new RanPark(lmp, seed);
+  random_unequal = new RanPark(lmp, seed);
+
+  force_reneighbor = 1;
+  next_reneighbor = update->ntimestep + 1;
+
+  ncatalog = maxcatalog = 0;
+  exchbufsize = 0;
+  triclinic = domain->triclinic;
+  groupbitall = 1 | groupbit;
+
+  nattempts = ninsert_acc = ndelete_acc = nsource_skip = 0.0;
+  nspecies_out = ncatalog_out = 0.0;
+  nblocks_offband = 0;
+  energy_stored = 0.0;
+  beta = sigma = gas_mass = 0.0;
+}
