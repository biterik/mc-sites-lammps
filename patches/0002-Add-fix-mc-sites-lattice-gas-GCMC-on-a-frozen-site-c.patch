+/* ---------------------------------------------------------------------- */
+
+void FixMCSites::init()
+{
+  triclinic = domain->triclinic;
+
+  if (domain->dimension == 2) error->all(FLERR, "Cannot use fix mc/sites in a 2d simulation");
+  if (atom->tag_enable == 0) error->all(FLERR, "Fix mc/sites requires atom IDs");
+  if (!atom->mass) error->all(FLERR, "Fix mc/sites requires per atom type masses");
+  if (mcs_type <= 0 || mcs_type > atom->ntypes)
+    error->all(FLERR, "Invalid atom type {} in fix mc/sites command", mcs_type);
+  gas_mass = atom->mass[mcs_type];
+  if (gas_mass <= 0.0) error->all(FLERR, "Fix mc/sites species type {} has no mass", mcs_type);
+  if (charge_flag && !atom->q_flag)
+    error->all(FLERR, "Fix mc/sites charge keyword requires an atom style with charge");
+  if (neighbor->build_once)
+    error->all(FLERR, "Cannot use fix mc/sites with neigh_modify once yes: "
+                      "reneighboring is required after every MC block");
+
+  // the fix resolves owners of catalogue entries through the global atom map;
+  // create one if absent (same pattern as the GRACE pair styles)
+
+  if (atom->map_style == Atom::MAP_NONE) {
+    atom->map_init();
+    atom->map_set();
+  }
+
+  if (idregion) {
+    region = domain->get_region_by_id(idregion);
+    if (!region) error->all(FLERR, "Region {} for fix mc/sites does not exist", idregion);
+  }
+
+  if (idsites_compute) {
+    sites_compute = modify->get_compute_by_id(idsites_compute);
+    if (!sites_compute)
+      error->all(FLERR, "Compute {} for fix mc/sites does not exist", idsites_compute);
+    if (!sites_compute->local_flag || sites_compute->size_local_cols < 4)
+      error->all(FLERR,
+                 "Compute {} for fix mc/sites must produce a local array with at least "
+                 "columns x y z clearance (e.g. compute sites/voronoi)",
+                 idsites_compute);
+  }
+
+  if (temp_var_name) {
+    temp_var = input->variable->find(temp_var_name);
+    if (temp_var < 0)
+      error->all(FLERR, "Variable {} for fix mc/sites temperature does not exist", temp_var_name);
+    if (!input->variable->equalstyle(temp_var))
+      error->all(FLERR, "Variable {} for fix mc/sites temperature is not equal-style",
+                 temp_var_name);
+    temp = input->variable->compute_equal(temp_var);
+    if (temp <= 0.0)
+      error->all(FLERR, "Fix mc/sites temperature variable gave {}, must be > 0.0", temp);
+  }
+  if (mu_var_name) {
+    mu_var = input->variable->find(mu_var_name);
+    if (mu_var < 0)
+      error->all(FLERR, "Variable {} for fix mc/sites mu does not exist", mu_var_name);
+    if (!input->variable->equalstyle(mu_var))
+      error->all(FLERR, "Variable {} for fix mc/sites mu is not equal-style", mu_var_name);
+  }
+
+  // exactly one mc/sites fix may drive a given species type
+
+  for (auto &ifix : modify->get_fix_by_style("^mc/sites")) {
+    auto other = dynamic_cast<FixMCSites *>(ifix);
+    if (other && other != this && other->species_type() == mcs_type)
+      error->all(FLERR, "Fix mc/sites instances {} and {} both drive atom type {}", id, other->id,
+                 mcs_type);
+  }
+
+  c_pe = modify->get_compute_by_id("thermo_pe");
+  if (!c_pe) error->all(FLERR, "Fix mc/sites could not find the thermo_pe compute");
+
+  // GRACE energy-only hook: fork pair styles expose an int flag via extract();
+  // returns null (and stays unused) for every other pair style
+
+  grace_energy_only = nullptr;
+  if (force->pair) {
+    int dim;
+    grace_energy_only = (int *) force->pair->extract("compute_energy_only", dim);
+  }
+
+  if (sites_file && !file_xyz) read_sites_file();
+}
