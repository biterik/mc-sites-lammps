+  int ntrials;             // trial flips per block
+  int mcs_type;            // atom type of the MC species
+  int seed;                // RNG seed
+  double temp;             // MC temperature
+  char *temp_var_name;     // equal-style variable for temp (or null)
+  int temp_var;
+  int mode;                // MODE_GC or MODE_SOURCE
+  double mu;               // lattice-gas chemical potential (gc mode)
+  char *mu_var_name;       // equal-style variable for mu (or null)
+  int mu_var;
+  int rate;                // insertions per invocation (source mode)
+  double tfac_insert;      // inserted-atom velocity temperature scale
+  double charge_val;       // charge assigned to inserted atoms
+  int charge_flag;
+  bigint maxspecies;       // cap on N_species (insertions skipped above)
+  double overlap_cutoff;   // pre-reject insertions at clearance below this
+
+  char *idsites_compute;    // sites compute ID (dynamic catalogue) or null
+  class Compute *sites_compute;
+  char *sites_file;         // static site-list file (validation mode) or null
+  int nfile_sites;          // rows in the file list
+  double **file_xyz;        // file site positions (wrapped into the box)
+
+  char *idregion;
+  class Region *region;
+
+  class RanPark *random_equal;      // identical stream on all ranks
+  class RanPark *random_unequal;    // owner-only draws (velocities)
+  class Compute *c_pe;
+  int *grace_energy_only;           // GRACE extract hook (or null)
+
+  double beta, sigma, gas_mass;
+  double energy_stored;
+  int triclinic;
+  double *sublo, *subhi;
+  int groupbitall;
+
