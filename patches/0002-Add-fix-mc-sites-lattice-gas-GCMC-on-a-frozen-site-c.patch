+/* ----------------------------------------------------------------------
+   read the static site list: one "x y z" triple per line, # comments and
+   blank lines ignored; positions are remapped into the periodic box
+------------------------------------------------------------------------- */
+
+void FixMCSites::read_sites_file()
+{
+  int nsites = 0;
+  double *buf = nullptr;
+
+  if (comm->me == 0) {
+    FILE *fp = fopen(sites_file, "r");
+    if (!fp) error->one(FLERR, "Cannot open fix mc/sites file {}: {}", sites_file,
+                        utils::getsyserror());
+    int maxsites = CATDELTA;
+    memory->create(buf, 3 * maxsites, "mc/sites:filebuf");
+    char line[1024];
+    int nline = 0;
+    while (fgets(line, 1024, fp)) {
+      nline++;
+      char *ptr = line;
+      while (*ptr == ' ' || *ptr == '\t') ptr++;
+      if (*ptr == '#' || *ptr == '\n' || *ptr == '\r' || *ptr == '\0') continue;
+      double xx, yy, zz;
+      if (sscanf(ptr, "%lg %lg %lg", &xx, &yy, &zz) != 3)
+        error->one(FLERR, "Fix mc/sites file {} line {} is not an x y z triple", sites_file,
+                   nline);
+      if (nsites == maxsites) {
+        maxsites += CATDELTA;
+        memory->grow(buf, 3 * maxsites, "mc/sites:filebuf");
+      }
+      buf[3 * nsites] = xx;
+      buf[3 * nsites + 1] = yy;
+      buf[3 * nsites + 2] = zz;
+      nsites++;
+    }
+    fclose(fp);
+    if (nsites == 0) error->one(FLERR, "Fix mc/sites file {} contains no sites", sites_file);
+  }
+
+  MPI_Bcast(&nsites, 1, MPI_INT, 0, world);
+  nfile_sites = nsites;
+  memory->create(file_xyz, nfile_sites, 3, "mc/sites:file_xyz");
+  if (comm->me == 0) memcpy(&file_xyz[0][0], buf, 3 * nfile_sites * sizeof(double));
+  memory->destroy(buf);
+  MPI_Bcast(&file_xyz[0][0], 3 * nfile_sites, MPI_DOUBLE, 0, world);
+
+  for (int i = 0; i < nfile_sites; i++) domain->remap(file_xyz[i]);
+
+  if (comm->me == 0)
+    utils::logmesg(lmp, "Fix mc/sites {} read {} sites from file {}\n", id, nfile_sites,
+                   sites_file);
+}
+
+/* ---------------------------------------------------------------------- */
+
+void FixMCSites::catalog_append(const double *xyz, double clearance, tagint tag)
+{
+  if (ncatalog == maxcatalog) {
+    maxcatalog += CATDELTA;
+    catalog = (SiteEntry *) memory->srealloc(catalog, maxcatalog * sizeof(SiteEntry),
+                                             "mc/sites:catalog");
+  }
+  catalog[ncatalog].x[0] = xyz[0];
+  catalog[ncatalog].x[1] = xyz[1];
+  catalog[ncatalog].x[2] = xyz[2];
+  catalog[ncatalog].clearance = clearance;
+  catalog[ncatalog].tag = tag;
+  ncatalog++;
+}
+
+/* ----------------------------------------------------------------------
+   build the frozen catalogue for this MC block, identical on all ranks:
+   empty entries from the sites compute (gathered) or the static file,
+   occupied entries = current species atoms in group (and region)
+------------------------------------------------------------------------- */
+
+void FixMCSites::build_catalog()
+{
+  ncatalog = 0;
+  if (region) region->prematch();
+
+  // occupied entries first: species atoms in group (and region), gathered
+  // globally; needed below to veto file-list sites that are already occupied
+
+  double **x = atom->x;
+  int *mask = atom->mask;
+  int *type = atom->type;
+  tagint *tag = atom->tag;
+  int nlocal = atom->nlocal;
+
+  int noccl = 0;
+  double *occbuf;
+  memory->create(occbuf, 4 * MAX(nlocal, 1), "mc/sites:occbuf");
+  for (int i = 0; i < nlocal; i++) {
+    if (!(mask[i] & groupbit)) continue;
+    if (type[i] != mcs_type) continue;
+    if (region && !region->match(x[i][0], x[i][1], x[i][2])) continue;
+    occbuf[4 * noccl] = x[i][0];
+    occbuf[4 * noccl + 1] = x[i][1];
+    occbuf[4 * noccl + 2] = x[i][2];
+    occbuf[4 * noccl + 3] = ubuf(tag[i]).d;
+    noccl++;
+  }
+
+  int nprocs = comm->nprocs;
+  int *orecvcounts, *odispls;
+  memory->create(orecvcounts, nprocs, "mc/sites:occrecv");
+  memory->create(odispls, nprocs, "mc/sites:occdispls");
+  int osendcount = 4 * noccl;
+  MPI_Allgather(&osendcount, 1, MPI_INT, orecvcounts, 1, MPI_INT, world);
+  int ototal = 0;
+  for (int p = 0; p < nprocs; p++) {
+    odispls[p] = ototal;
+    ototal += orecvcounts[p];
+  }
+  double *occall;
+  memory->create(occall, MAX(ototal, 1), "mc/sites:occall");
+  MPI_Allgatherv(occbuf, osendcount, MPI_DOUBLE, occall, orecvcounts, odispls, MPI_DOUBLE,
+                 world);
+  int nocc = ototal / 4;
+  memory->destroy(occbuf);
+  memory->destroy(orecvcounts);
+  memory->destroy(odispls);
+
+  // empty entries
+
+  if (sites_compute) {
+    if (!(sites_compute->invoked_flag & Compute::INVOKED_LOCAL)) {
+      sites_compute->compute_local();
+      sites_compute->invoked_flag |= Compute::INVOKED_LOCAL;
+    }
+    int nlocalrows = sites_compute->size_local_rows;
+    int cols = sites_compute->size_local_cols;
+    double **larray = sites_compute->array_local;
+
+    int nprocs = comm->nprocs;
+    int *recvcounts, *displs;
+    memory->create(recvcounts, nprocs, "mc/sites:recvcounts");
+    memory->create(displs, nprocs, "mc/sites:displs");
+    int sendcount = 4 * nlocalrows;
+    MPI_Allgather(&sendcount, 1, MPI_INT, recvcounts, 1, MPI_INT, world);
+    int ntotal = 0;
+    for (int p = 0; p < nprocs; p++) {
+      displs[p] = ntotal;
+      ntotal += recvcounts[p];
+    }
+    double *sendbuf, *recvbuf;
+    memory->create(sendbuf, MAX(sendcount, 1), "mc/sites:sendbuf");
+    memory->create(recvbuf, MAX(ntotal, 1), "mc/sites:recvbuf");
+    for (int i = 0; i < nlocalrows; i++) {
+      sendbuf[4 * i] = larray[i][0];
+      sendbuf[4 * i + 1] = larray[i][1];
+      sendbuf[4 * i + 2] = larray[i][2];
+      sendbuf[4 * i + 3] = larray[i][3];    // clearance
+    }
+    MPI_Allgatherv(sendbuf, sendcount, MPI_DOUBLE, recvbuf, recvcounts, displs, MPI_DOUBLE,
+                   world);
+    int nsites = ntotal / 4;
+    for (int i = 0; i < nsites; i++) {
+      double *xyz = &recvbuf[4 * i];
+      if (region && !region->match(xyz[0], xyz[1], xyz[2])) continue;
+      catalog_append(xyz, recvbuf[4 * i + 3], 0);
+    }
+    memory->destroy(sendbuf);
+    memory->destroy(recvbuf);
+    memory->destroy(recvcounts);
+    memory->destroy(displs);
+  } else {
+    // static file list (validation mode): no clearance information ->
+    // "infinite" clearance (overlap_cutoff and source-mode guards inactive).
+    // A file site currently holding a species atom is occupied, not empty:
+    // drop file entries within OCCEPS of an occupied entry (exact match up
+    // to fp: inserted atoms sit exactly at site positions; file mode
+    // assumes a frozen host, see the doc Restrictions)
+    const double OCCEPS = 1.0e-6;
+    const double occepssq = OCCEPS * OCCEPS;
+    for (int i = 0; i < nfile_sites; i++) {
+      if (region && !region->match(file_xyz[i][0], file_xyz[i][1], file_xyz[i][2])) continue;
+      int taken = 0;
+      for (int j = 0; j < nocc; j++) {
+        double dx = file_xyz[i][0] - occall[4 * j];
+        double dy = file_xyz[i][1] - occall[4 * j + 1];
+        double dz = file_xyz[i][2] - occall[4 * j + 2];
+        if (dx * dx + dy * dy + dz * dz < occepssq) {
+          taken = 1;
+          break;
+        }
+      }
+      if (!taken) catalog_append(file_xyz[i], 1.0e30, 0);
+    }
+  }
+
+  // occupied entries appended after the empties
+
+  for (int i = 0; i < nocc; i++) {
+    double *xyz = &occall[4 * i];
+    tagint t = (tagint) ubuf(occall[4 * i + 3]).i;
+    catalog_append(xyz, 0.0, t);
+  }
+  memory->destroy(occall);
+}
+
+/* ----------------------------------------------------------------------
+   one MC block, following fix gcmc's placement in the timestep
+------------------------------------------------------------------------- */
+
+void FixMCSites::pre_exchange()
+{
+  if (next_reneighbor != update->ntimestep) return;
+
+  // per-block parameter refresh (equal-style variables)
+
+  if (temp_var >= 0) {
+    temp = input->variable->compute_equal(temp_var);
+    if (temp <= 0.0)
+      error->all(FLERR, "Fix mc/sites temperature variable gave {}, must be > 0.0", temp);
+  }
+  if (mu_var >= 0) mu = input->variable->compute_equal(mu_var);
+  beta = 1.0 / (force->boltz * temp);
+  sigma = sqrt(force->boltz * temp * tfac_insert / gas_mass / force->mvv2e);
+
+  if (triclinic) {
+    sublo = domain->sublo_lamda;
+    subhi = domain->subhi_lamda;
+  } else {
+    sublo = domain->sublo;
+    subhi = domain->subhi;
+  }
+
+  // re-home atoms, rebuild ghosts and neighbor lists
+
+  if (triclinic) domain->x2lamda(atom->nlocal);
+  domain->pbc();
+  comm->exchange();
+  atom->nghost = 0;
+  comm->borders();
+  if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+  if (modify->n_pre_neighbor) modify->pre_neighbor();
+  neighbor->build(1);
+
+  build_catalog();
+
+  if (ncatalog == 0) {
+    if (comm->me == 0)
+      error->warning(FLERR, "Fix mc/sites {}: empty site catalogue, no MC moves attempted", id);
+    next_reneighbor = update->ntimestep + mcs_nevery;
+    return;
+  }
+
+  // activate the GRACE energy-only signature for the whole MC block
+
+  if (grace_energy_only) *grace_energy_only = 1;
+
+  energy_stored = energy_full();
+
+  double attempts_before = nattempts;
+  double accepted_before = ninsert_acc + ndelete_acc;
+
+  if (mode == MODE_GC) {
+    for (int itrial = 0; itrial < ntrials; itrial++) {
+      int idx = (int) (random_equal->uniform() * ncatalog);
+      if (idx >= ncatalog) idx = ncatalog - 1;
+      if (catalog[idx].tag == 0)
+        attempt_insertion(idx);
+      else
+        attempt_deletion(idx);
+    }
+  } else
+    run_source_mode();
+
+  if (grace_energy_only) *grace_energy_only = 0;
+
+  // final re-home so the integrator continues from a consistent state
+
+  if (triclinic) domain->x2lamda(atom->nlocal);
+  domain->pbc();
+  comm->exchange();
+  atom->nghost = 0;
+  comm->borders();
+  if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+
+  // block bookkeeping for the output vector + acceptance-ratio warning
+
+  bigint nocc = 0;
+  for (int i = 0; i < ncatalog; i++)
+    if (catalog[i].tag != 0) nocc++;
+  nspecies_out = (double) nocc;
+  ncatalog_out = (double) ncatalog;
+
+  double block_attempts = nattempts - attempts_before;
+  if (mode == MODE_GC && block_attempts > 0.0) {
+    double ratio = (ninsert_acc + ndelete_acc - accepted_before) / block_attempts;
+    if (ratio < 0.01 || ratio > 0.99)
+      nblocks_offband++;
+    else
+      nblocks_offband = 0;
+    if (nblocks_offband == OFFBAND_WARN_BLOCKS && comm->me == 0)
+      error->warning(FLERR,
+                     "Fix mc/sites {}: acceptance ratio {:.4} outside [0.01,0.99] for {} "
+                     "consecutive blocks",
+                     id, ratio, OFFBAND_WARN_BLOCKS);
+  }
+
+  next_reneighbor = update->ntimestep + mcs_nevery;
+}
+
+/* ----------------------------------------------------------------------
+   which rank owns a position: remap into the box, test the subdomain
+   (fix gcmc pattern); returns 1 on exactly one rank
+------------------------------------------------------------------------- */
+
+int FixMCSites::site_owner_flag(double *coord)
+{
+  domain->remap(coord);
+  if (triclinic) {
+    double lamda[3];
+    domain->x2lamda(coord, lamda);
+    return (lamda[0] >= sublo[0] && lamda[0] < subhi[0] && lamda[1] >= sublo[1] &&
+            lamda[1] < subhi[1] && lamda[2] >= sublo[2] && lamda[2] < subhi[2]);
+  }
+  return (coord[0] >= sublo[0] && coord[0] < subhi[0] && coord[1] >= sublo[1] &&
+          coord[1] < subhi[1] && coord[2] >= sublo[2] && coord[2] < subhi[2]);
+}
+
+/* ----------------------------------------------------------------------
+   tag of the atom just created via tag_extend, identical on all ranks
+------------------------------------------------------------------------- */
+
+tagint FixMCSites::global_new_tag(int proc_flag)
+{
+  tagint newtag = 0;
+  if (proc_flag) newtag = atom->tag[atom->nlocal - 1];
+  tagint newtag_all;
+  MPI_Allreduce(&newtag, &newtag_all, 1, MPI_LMP_TAGINT, MPI_MAX, world);
+  return newtag_all;
+}
+
+/* ----------------------------------------------------------------------
+   trial insertion at empty catalogue entry idx
+   acceptance: min(1, exp(-beta*(dU - mu)))  [lattice-gas convention]
+------------------------------------------------------------------------- */
+
+void FixMCSites::attempt_insertion(int idx)
+{
+  nattempts += 1.0;
+
+  if (maxspecies >= 0) {
+    bigint nocc = 0;
+    for (int i = 0; i < ncatalog; i++)
+      if (catalog[i].tag != 0) nocc++;
+    if (nocc >= maxspecies) return;
+  }
+
+  // overlap pre-rejection: no energy evaluation for hopeless insertions
+
+  if (overlap_cutoff > 0.0 && catalog[idx].clearance < overlap_cutoff) return;
+
+  double energy_before = energy_stored;
+  double coord[3] = {catalog[idx].x[0], catalog[idx].x[1], catalog[idx].x[2]};
+  int proc_flag = site_owner_flag(coord);
+
+  if (proc_flag) {
+    atom->avec->create_atom(mcs_type, coord);
+    int m = atom->nlocal - 1;
+    atom->mask[m] = groupbitall;
+    atom->v[m][0] = random_unequal->gaussian() * sigma;
+    atom->v[m][1] = random_unequal->gaussian() * sigma;
+    atom->v[m][2] = random_unequal->gaussian() * sigma;
+    if (charge_flag) atom->q[m] = charge_val;
+    modify->create_attribute(m);
+  }
+
+  atom->natoms++;
+  atom->tag_extend();
+  atom->map_init();
+  atom->nghost = 0;
+  if (triclinic) domain->x2lamda(atom->nlocal);
+  comm->borders();
+  if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+  if (force->kspace) force->kspace->qsum_qsq();
+  if (force->pair->tail_flag) force->pair->reinit();
+
+  tagint newtag = global_new_tag(proc_flag);
+
+  double energy_after = energy_full();
+
+  if (energy_after < MAXENERGYTEST &&
+      random_equal->uniform() < exp(-beta * (energy_after - energy_before - mu))) {
+    ninsert_acc += 1.0;
+    energy_stored = energy_after;
+    catalog[idx].tag = newtag;
+  } else {
+    atom->natoms--;
+    if (proc_flag) atom->nlocal--;
+    if (force->kspace) force->kspace->qsum_qsq();
+    if (force->pair->tail_flag) force->pair->reinit();
+    energy_stored = energy_before;
+  }
+}
+
+/* ----------------------------------------------------------------------
+   trial deletion of the atom at occupied catalogue entry idx
+   acceptance: min(1, exp(-beta*(dU + mu)))  [lattice-gas convention]
+
+   unlike fix gcmc (exclusion-group masking, which leaves the isolated-atom
+   energy in the total -- wrong for ML potentials) the atom is really
+   removed for the trial and restored exactly via pack/unpack_exchange on
+   rejection (QUESTIONS.md Q4)
+------------------------------------------------------------------------- */
+
+void FixMCSites::attempt_deletion(int idx)
+{
+  nattempts += 1.0;
+
+  double energy_before = energy_stored;
+  tagint dtag = catalog[idx].tag;
+  int m = atom->map(dtag);
+  int proc_flag = (m >= 0 && m < atom->nlocal);
+
+  if (proc_flag) {
+    // buffer sized like Comm::init_exchange: avec extra + fix extras + slack
+    // (the base per-atom pack of ~11 doubles is well inside the slack)
+    int needed = atom->avec->maxexchange + 1024;
+    for (const auto &ifix : modify->get_fix_list()) needed += ifix->maxexchange;
+    if (exchbufsize < needed) {
+      memory->destroy(exchbuf);
+      exchbufsize = needed;
+      memory->create(exchbuf, exchbufsize, "mc/sites:exchbuf");
+    }
+    atom->avec->pack_exchange(m, exchbuf);
+    atom->avec->copy(atom->nlocal - 1, m, 1);
+    atom->nlocal--;
+  }
+  atom->natoms--;
+  atom->map_init();
+  atom->nghost = 0;
+  if (triclinic) domain->x2lamda(atom->nlocal);
+  comm->borders();
+  if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+  if (force->kspace) force->kspace->qsum_qsq();
+  if (force->pair->tail_flag) force->pair->reinit();
+
+  double energy_after = energy_full();
+
+  if (random_equal->uniform() < exp(-beta * (energy_after - energy_before + mu))) {
+    ndelete_acc += 1.0;
+    energy_stored = energy_after;
+    // entry stays in the catalogue as empty at the deleted atom's position:
+    // the reverse move exists within the frozen block
+    catalog[idx].tag = 0;
+  } else {
+    if (proc_flag) atom->avec->unpack_exchange(exchbuf);    // increments nlocal
+    atom->natoms++;
+    atom->map_init();
+    atom->nghost = 0;
+    if (triclinic) domain->x2lamda(atom->nlocal);
+    comm->borders();
+    if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+    if (force->kspace) force->kspace->qsum_qsq();
+    if (force->pair->tail_flag) force->pair->reinit();
+    energy_stored = energy_before;
+  }
+}
+
+/* ----------------------------------------------------------------------
+   source mode: insert `rate` atoms per invocation at distinct random
+   empty entries, unconditionally (irradiation-style); entries failing the
+   overlap guard are skipped and counted
+------------------------------------------------------------------------- */
+
+void FixMCSites::run_source_mode()
+{
+  int ninserted = 0;
+  int nempty = 0;
+  for (int i = 0; i < ncatalog; i++)
+    if (catalog[i].tag == 0) nempty++;
+
+  while (ninserted < rate) {
+    if (nempty == 0) {
+      nsource_skip += rate - ninserted;
+      if (comm->me == 0)
+        error->warning(FLERR, "Fix mc/sites {}: site catalogue exhausted in source mode ({} "
+                              "insertions skipped)",
+                       id, rate - ninserted);
+      break;
+    }
+
+    // pick uniformly among the current empty entries (synchronized draw)
+
+    int which = (int) (random_equal->uniform() * nempty);
+    if (which >= nempty) which = nempty - 1;
+    int idx = -1;
+    for (int i = 0, k = 0; i < ncatalog; i++) {
+      if (catalog[i].tag == 0) {
+        if (k == which) {
+          idx = i;
+          break;
+        }
+        k++;
+      }
+    }
+
+    nattempts += 1.0;
+    nempty--;    // this entry is used up either way (distinct entries)
+
+    if (overlap_cutoff > 0.0 && catalog[idx].clearance < overlap_cutoff) {
+      nsource_skip += 1.0;
+      catalog[idx].tag = -1;    // mark consumed but not occupied
+      continue;
+    }
+
+    double coord[3] = {catalog[idx].x[0], catalog[idx].x[1], catalog[idx].x[2]};
+    int proc_flag = site_owner_flag(coord);
+
+    if (proc_flag) {
+      atom->avec->create_atom(mcs_type, coord);
+      int m = atom->nlocal - 1;
+      atom->mask[m] = groupbitall;
+      atom->v[m][0] = random_unequal->gaussian() * sigma;
+      atom->v[m][1] = random_unequal->gaussian() * sigma;
+      atom->v[m][2] = random_unequal->gaussian() * sigma;
+      if (charge_flag) atom->q[m] = charge_val;
+      modify->create_attribute(m);
+    }
+
+    atom->natoms++;
+    atom->tag_extend();
+    atom->map_init();
+    atom->nghost = 0;
+    if (triclinic) domain->x2lamda(atom->nlocal);
+    comm->borders();
+    if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+    if (force->kspace) force->kspace->qsum_qsq();
+    if (force->pair->tail_flag) force->pair->reinit();
+
+    catalog[idx].tag = global_new_tag(proc_flag);
+    ninsert_acc += 1.0;
+    ninserted++;
+  }
+
+  // restore "consumed" markers to empty for the occupancy count
+
+  for (int i = 0; i < ncatalog; i++)
+    if (catalog[i].tag == -1) catalog[i].tag = 0;
+}
+
+/* ----------------------------------------------------------------------
+   current total potential energy, identical on all ranks
+   (fix gcmc energy_full pattern; forces are computed and discarded unless
+   the pair style honors the energy-only hint / GRACE flag)
+------------------------------------------------------------------------- */
+
+double FixMCSites::energy_full()
+{
+  if (triclinic) domain->x2lamda(atom->nlocal);
+  domain->pbc();
+  comm->exchange();
+  atom->nghost = 0;
+  comm->borders();
+  if (triclinic) domain->lamda2x(atom->nlocal + atom->nghost);
+  if (modify->n_pre_neighbor) modify->pre_neighbor();
+  neighbor->build(1);
+
+  int eflag = ENERGY_GLOBAL | ENERGY_ONLY_HINT;
+  int vflag = 0;
+
+  // zero forces: they accumulate across repeated evaluations in one step
+
+  size_t nbytes = sizeof(double) * (atom->nlocal + atom->nghost);
+  if (nbytes) memset(&atom->f[0][0], 0, 3 * nbytes);
+
+  if (modify->n_pre_force) modify->pre_force(vflag);
+  if (force->pair) force->pair->compute(eflag, vflag);
+  if (atom->molecular != Atom::ATOMIC) {
+    if (force->bond) force->bond->compute(eflag, vflag);
+    if (force->angle) force->angle->compute(eflag, vflag);
+    if (force->dihedral) force->dihedral->compute(eflag, vflag);
+    if (force->improper) force->improper->compute(eflag, vflag);
+  }
+  if (force->kspace) force->kspace->compute(eflag, vflag);
+  if (modify->n_post_force_any) modify->post_force(vflag);
+
+  update->eflag_global = update->ntimestep;
+  return c_pe->compute_scalar();
+}
+
+/* ---------------------------------------------------------------------- */
+
+double FixMCSites::compute_vector(int n)
+{
+  switch (n) {
+    case 0:
+      return nattempts;
+    case 1:
+      return ninsert_acc;
+    case 2:
+      return ndelete_acc;
+    case 3:
+      return nspecies_out;
+    case 4:
+      return ncatalog_out;
+    case 5:
+      return (ncatalog_out > 0.0) ? nspecies_out / ncatalog_out : 0.0;
+    case 6:
+      return (nattempts > 0.0) ? (ninsert_acc + ndelete_acc) / nattempts : 0.0;
+    case 7:
+      return nsource_skip;
+  }
+  return 0.0;
+}
+
+/* ----------------------------------------------------------------------
+   pack RNG states + counters into restart file (fix gcmc pattern)
+------------------------------------------------------------------------- */
+
+void FixMCSites::write_restart(FILE *fp)
+{
+  int n = 0;
+  double list[9];
+  list[n++] = random_equal->state();
+  list[n++] = random_unequal->state();
+  list[n++] = ubuf(next_reneighbor).d;
+  list[n++] = nattempts;
+  list[n++] = ninsert_acc;
+  list[n++] = ndelete_acc;
+  list[n++] = nsource_skip;
+  list[n++] = ubuf(update->ntimestep).d;
+  list[n++] = 0.0;    // reserved
+
+  if (comm->me == 0) {
+    int size = n * sizeof(double);
+    fwrite(&size, sizeof(int), 1, fp);
+    fwrite(list, sizeof(double), n, fp);
+  }
+}
+
+/* ---------------------------------------------------------------------- */
+
+void FixMCSites::restart(char *buf)
+{
+  int n = 0;
+  auto list = (double *) buf;
+
+  seed = (int) list[n++];
+  random_equal->reset(seed);
+  seed = (int) list[n++];
+  random_unequal->reset(seed);
+  next_reneighbor = (bigint) ubuf(list[n++]).i;
+  nattempts = list[n++];
+  ninsert_acc = list[n++];
+  ndelete_acc = list[n++];
+  nsource_skip = list[n++];
+
+  bigint ntimestep_restart = (bigint) ubuf(list[n++]).i;
+  if (ntimestep_restart != update->ntimestep)
+    error->all(FLERR, "Must not reset timestep when restarting fix mc/sites");
+}
+
+/* ---------------------------------------------------------------------- */
+
+double FixMCSites::memory_usage()
+{
+  double bytes = (double) maxcatalog * sizeof(SiteEntry);
+  bytes += (double) exchbufsize * sizeof(double);
+  bytes += (double) nfile_sites * 3 * sizeof(double);
+  return bytes;
+}
