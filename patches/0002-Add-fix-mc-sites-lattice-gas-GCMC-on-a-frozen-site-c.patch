+  int exchbufsize;
+
+  SiteEntry *catalog;    // frozen per-block catalogue, replicated on all ranks
+  int ncatalog, maxcatalog;
+
+  // counters / output vector state
+  double nattempts, ninsert_acc, ndelete_acc, nsource_skip;
+  double nspecies_out, ncatalog_out;
+  int nblocks_offband;    // consecutive blocks with acceptance out of [0.01,0.99]
+
+  void build_catalog();
+  void catalog_append(const double *xyz, double clearance, tagint tag);
+  void read_sites_file();
+  void attempt_insertion(int);
+  void attempt_deletion(int);
+  void run_source_mode();
+  double energy_full();
