+static constexpr double MAXENERGYTEST = 1.0e50;    // fix gcmc overlap guard convention
+static constexpr int CATDELTA = 4096;              // catalogue grow chunk
+// numerically equal to upstream force.h ENERGY_ONLY (absent in this fork's
+// enum); harmless extra eflag bit where unknown, energy-only hint upstream
+static constexpr int ENERGY_ONLY_HINT = 0x04;
+static constexpr int OFFBAND_WARN_BLOCKS = 10;     // acceptance-ratio warning patience
