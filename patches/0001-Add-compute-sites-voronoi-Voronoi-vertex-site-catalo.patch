+/* ---------------------------------------------------------------------- */
+
+void ComputeSitesVoronoi::init()
+{
+  if (domain->dimension == 2)
+    error->all(FLERR, "Compute sites/voronoi requires a 3d simulation");
+
+  if (idregion) {
+    region = domain->get_region_by_id(idregion);
+    if (!region)
+      error->all(FLERR, "Region {} for compute sites/voronoi does not exist", idregion);
+  }
+
+  if (rminstr) {
+    rminvar = input->variable->find(rminstr);
+    if (rminvar < 0)
+      error->all(FLERR, "Variable {} for compute sites/voronoi rmin does not exist", rminstr);
+    if (!input->variable->equalstyle(rminvar))
+      error->all(FLERR, "Variable {} for compute sites/voronoi rmin is not equal-style", rminstr);
+  }
+  if (rmaxstr) {
+    rmaxvar = input->variable->find(rmaxstr);
+    if (rmaxvar < 0)
+      error->all(FLERR, "Variable {} for compute sites/voronoi rmax does not exist", rmaxstr);
+    if (!input->variable->equalstyle(rmaxvar))
+      error->all(FLERR, "Variable {} for compute sites/voronoi rmax is not equal-style", rmaxstr);
+  }
+  if (vminstr) {
+    vminvar = input->variable->find(vminstr);
+    if (vminvar < 0)
+      error->all(FLERR, "Variable {} for compute sites/voronoi vmin does not exist", vminstr);
+    if (!input->variable->equalstyle(vminvar))
+      error->all(FLERR, "Variable {} for compute sites/voronoi vmin is not equal-style", vminstr);
+  }
+  if (vmaxstr) {
+    vmaxvar = input->variable->find(vmaxstr);
+    if (vmaxvar < 0)
+      error->all(FLERR, "Variable {} for compute sites/voronoi vmax does not exist", vmaxstr);
+    if (!input->variable->equalstyle(vmaxvar))
+      error->all(FLERR, "Variable {} for compute sites/voronoi vmax is not equal-style", vmaxstr);
+  }
+}
+
+/* ---------------------------------------------------------------------- */
+
+void ComputeSitesVoronoi::evaluate_variables()
+{
+  if (rminvar >= 0) rmin = input->variable->compute_equal(rminvar);
+  if (rmaxvar >= 0) rmax = input->variable->compute_equal(rmaxvar);
+  if (vminvar >= 0) vmin = input->variable->compute_equal(vminvar);
+  if (vmaxvar >= 0) vmax = input->variable->compute_equal(vmaxvar);
+  if (rmin > rmax)
+    error->all(FLERR, "Compute sites/voronoi clearance window is empty: rmin {} > rmax {}", rmin,
+               rmax);
+  if (vmin > vmax)
+    error->all(FLERR, "Compute sites/voronoi volume window is empty: vmin {} > vmax {}", vmin,
+               vmax);
+}
+
+/* ----------------------------------------------------------------------
+   build the site catalogue for this processor:
+   1. voro++ tessellation of all group atoms (local + ghost) in the
+      subdomain extended by the ghost cutoff (mirrors compute voronoi/atom)
+   2. collect cell vertices (absolute position + empty-sphere radius =
+      distance to generator) inside the subdomain + merge halo
+   3. single-linkage clustering with cutoff rmerge; cluster -> centroid,
+      clearance = min over members
+   4. keep only clusters whose centroid lies in this rank's subdomain
+      (half-open [sublo,subhi) -> globally duplicate-free)
+   5. apply criteria: clearance window, region, coordination, occcut,
+      optional probe Voronoi volume window
+------------------------------------------------------------------------- */
+
+void ComputeSitesVoronoi::compute_local()
+{
+  invoked_local = update->ntimestep;
+  evaluate_variables();
+
+  const int nlocal = atom->nlocal;
+  const int nall = nlocal + atom->nghost;
+  const int triclinic = domain->triclinic;
+  double **x = atom->x;
+  int *mask = atom->mask;
+
+  // per-processor voro++ container bounds (see compute_voronoi_atom.cpp buildCells)
+
+  double *cut = comm->cutghost;
+  double sublo_bound[3], subhi_bound[3];
+
+  if (triclinic) {
+    double sublo_bound_lamda[3], subhi_bound_lamda[3];
+    for (int d = 0; d < 3; d++) {
+      sublo_bound_lamda[d] = domain->sublo_lamda[d] - cut[d] - BOUND_EPS;
+      subhi_bound_lamda[d] = domain->subhi_lamda[d] + cut[d] + BOUND_EPS;
+      if (domain->periodicity[d] == 0) {
+        sublo_bound_lamda[d] = MAX(sublo_bound_lamda[d], 0.0);
+        subhi_bound_lamda[d] = MIN(subhi_bound_lamda[d], 1.0);
+      }
+    }
+    domain->bbox(sublo_bound_lamda, subhi_bound_lamda, sublo_bound, subhi_bound);
+  } else {
+    for (int d = 0; d < 3; d++) {
+      sublo_bound[d] = domain->sublo[d] - cut[d] - BOUND_EPS;
+      subhi_bound[d] = domain->subhi[d] + cut[d] + BOUND_EPS;
+      if (domain->periodicity[d] == 0) {
+        sublo_bound[d] = MAX(sublo_bound[d], domain->boxlo[d]);
+        subhi_bound[d] = MIN(subhi_bound[d], domain->boxhi[d]);
+      }
+    }
+  }
+
+  // vertex collection window: subdomain + halo of MERGE_MARGIN*rmerge so
+  // that merge clusters straddling rank boundaries see all their members.
+  // window tests are in lamda coordinates for triclinic boxes.
+
+  double halo = MERGE_MARGIN * rmerge;
+  double win_lo[3], win_hi[3];
+  if (triclinic) {
+    for (int d = 0; d < 3; d++) {
+      double halo_lamda = halo / domain->prd[d];
+      win_lo[d] = domain->sublo_lamda[d] - halo_lamda;
+      win_hi[d] = domain->subhi_lamda[d] + halo_lamda;
+    }
+  } else {
+    for (int d = 0; d < 3; d++) {
+      win_lo[d] = domain->sublo[d] - halo;
+      win_hi[d] = domain->subhi[d] + halo;
+    }
+  }
+
+  // voro++ spatial hash sizing: ~8 particles per block
+
+  double blen[3], V;
+  for (int d = 0; d < 3; d++) blen[d] = subhi_bound[d] - sublo_bound[d];
+  V = blen[0] * blen[1] * blen[2];
+  int nblk[3];
+  for (int d = 0; d < 3; d++) {
+    nblk[d] = (int) round(blen[d] * pow((double) MAX(nall, 1) / (V * 8.0), 0.333333));
+    if (nblk[d] < 1) nblk[d] = 1;
+  }
+
+  voro::container con(sublo_bound[0], subhi_bound[0], sublo_bound[1], subhi_bound[1],
+                      sublo_bound[2], subhi_bound[2], nblk[0], nblk[1], nblk[2], false, false,
+                      false, 8);
+
+  for (int i = 0; i < nall; i++)
+    if (mask[i] & groupbit) con.put(i, x[i][0], x[i][1], x[i][2]);
+
+  // collect raw vertices (absolute position + clearance) inside the window
+
+  std::vector<double> vx, vy, vz, vr;
+  std::vector<double> vbuf;
+  voro::voronoicell cell;
+  voro::c_loop_all cl(con);
+  if (cl.start()) do {
+      if (!con.compute_cell(cell, cl)) continue;
+      double gx, gy, gz;
+      cl.pos(gx, gy, gz);
+      cell.vertices(gx, gy, gz, vbuf);
+      int nv = (int) vbuf.size() / 3;
+      for (int k = 0; k < nv; k++) {
+        double p[3] = {vbuf[3 * k], vbuf[3 * k + 1], vbuf[3 * k + 2]};
+        double wtest[3] = {p[0], p[1], p[2]};
+        if (triclinic) domain->x2lamda(p, wtest);
+        if (wtest[0] < win_lo[0] || wtest[0] >= win_hi[0] || wtest[1] < win_lo[1] ||
+            wtest[1] >= win_hi[1] || wtest[2] < win_lo[2] || wtest[2] >= win_hi[2])
+          continue;
+        double dx = p[0] - gx, dy = p[1] - gy, dz = p[2] - gz;
+        vx.push_back(p[0]);
+        vy.push_back(p[1]);
+        vz.push_back(p[2]);
+        vr.push_back(sqrt(dx * dx + dy * dy + dz * dz));
+      }
+    } while (cl.inc());
+
+  int nvert = (int) vx.size();
+
+  // single-linkage clustering with cutoff rmerge via a cell list
+
+  std::vector<int> parent(nvert);
+  for (int i = 0; i < nvert; i++) parent[i] = i;
+
+  if (nvert) {
+    double vlo[3] = {vx[0], vy[0], vz[0]};
+    double vhi[3] = {vx[0], vy[0], vz[0]};
+    for (int i = 1; i < nvert; i++) {
+      vlo[0] = MIN(vlo[0], vx[i]);
+      vhi[0] = MAX(vhi[0], vx[i]);
+      vlo[1] = MIN(vlo[1], vy[i]);
+      vhi[1] = MAX(vhi[1], vy[i]);
+      vlo[2] = MIN(vlo[2], vz[i]);
+      vhi[2] = MAX(vhi[2], vz[i]);
+    }
+    BinGrid grid;
+    grid.setup(vlo, vhi, rmerge);
+    for (int i = 0; i < nvert; i++) {
+      double p[3] = {vx[i], vy[i], vz[i]};
+      grid.insert(p, i);
+    }
+    const double rmergesq = rmerge * rmerge;
+    std::vector<int> neigh;
+    for (int i = 0; i < nvert; i++) {
+      double p[3] = {vx[i], vy[i], vz[i]};
+      neigh.clear();
+      grid.gather_neighborhood(p, neigh);
+      for (int j : neigh) {
+        if (j >= i) continue;
+        double dx = vx[i] - vx[j], dy = vy[i] - vy[j], dz = vz[i] - vz[j];
+        if (dx * dx + dy * dy + dz * dz <= rmergesq) uf_union(parent, i, j);
+      }
+    }
+  }
+
+  // accumulate clusters: centroid + min clearance
+
+  std::vector<int> rootmap(nvert, -1);
+  std::vector<double> cx, cy, cz, cr;
+  std::vector<int> cn;
+  for (int i = 0; i < nvert; i++) {
+    int r = uf_find(parent, i);
+    int c = rootmap[r];
+    if (c < 0) {
+      c = (int) cx.size();
+      rootmap[r] = c;
+      cx.push_back(0.0);
+      cy.push_back(0.0);
+      cz.push_back(0.0);
+      cr.push_back(BIGWINDOW);
+      cn.push_back(0);
+    }
+    cx[c] += vx[i];
+    cy[c] += vy[i];
+    cz[c] += vz[i];
+    cr[c] = MIN(cr[c], vr[i]);
+    cn[c]++;
+  }
+  int nclust = (int) cx.size();
+  for (int c = 0; c < nclust; c++) {
+    cx[c] /= cn[c];
+    cy[c] /= cn[c];
+    cz[c] /= cn[c];
+  }
+
+  // criteria helpers: atom cell lists for coordination and occcut vetoes
+
+  BinGrid coordgrid, exclgrid;
+  double alo[3], ahi[3];
+  if ((coord_flag || occcut_flag) && nall) {
+    alo[0] = ahi[0] = x[0][0];
+    alo[1] = ahi[1] = x[0][1];
+    alo[2] = ahi[2] = x[0][2];
+    for (int i = 1; i < nall; i++)
+      for (int d = 0; d < 3; d++) {
+        alo[d] = MIN(alo[d], x[i][d]);
+        ahi[d] = MAX(ahi[d], x[i][d]);
+      }
+  }
+  if (coord_flag && nall) {
+    coordgrid.setup(alo, ahi, coord_rcut);
+    for (int i = 0; i < nall; i++) {
+      if (mask[i] & hostgroupbit) coordgrid.insert(x[i], i);
+    }
+  }
+  if (occcut_flag && nall) {
+    exclgrid.setup(alo, ahi, occcut);
+    for (int i = 0; i < nall; i++) {
+      if (mask[i] & exclgroupbit) exclgrid.insert(x[i], i);
+    }
+  }
+
+  if (region) region->prematch();
+
+  // ownership + criteria pass; fill the local array
+
+  double *sublo = triclinic ? domain->sublo_lamda : domain->sublo;
+  double *subhi = triclinic ? domain->subhi_lamda : domain->subhi;
+  const double coordcutsq = coord_rcut * coord_rcut;
+  const double occcutsq = occcut * occcut;
+  double cutghost_min = MIN(cut[0], MIN(cut[1], cut[2]));
+  std::vector<int> neigh;
+
+  // ownership tie-break: a site sitting exactly on a subdomain or periodic
+  // box face (common on ideal lattices) is computed by two ranks (or twice,
+  // as periodic images) with only last-ulp position differences.  Nudging the
+  // test coordinate by a fixed offset far above fp noise and far below any
+  // real inter-site distance makes exactly one copy pass its owner's
+  // half-open [sublo,subhi) test.  No wrapping: the partner image of a
+  // dropped high-face copy always exists on the low-face side.
+
+  double nudge[3];
+  if (triclinic)
+    nudge[0] = nudge[1] = nudge[2] = OWN_NUDGE;
+  else
+    for (int d = 0; d < 3; d++) nudge[d] = OWN_NUDGE * domain->prd[d];
+
+  int nsites = 0;
+  for (int c = 0; c < nclust; c++) {
+    double p[3] = {cx[c], cy[c], cz[c]};
+    double otest[3] = {p[0], p[1], p[2]};
+    if (triclinic) domain->x2lamda(p, otest);
+    for (int d = 0; d < 3; d++) otest[d] += nudge[d];
+    if (otest[0] < sublo[0] || otest[0] >= subhi[0] || otest[1] < sublo[1] ||
+        otest[1] >= subhi[1] || otest[2] < sublo[2] || otest[2] >= subhi[2])
+      continue;
+
+    if (cr[c] < rmin || cr[c] > rmax) continue;
+    if (region && !region->match(p[0], p[1], p[2])) continue;
+
+    int ncoord = 0;
+    if (coord_flag) {
+      neigh.clear();
+      coordgrid.gather_neighborhood(p, neigh);
+      for (int j : neigh) {
+        double dx = p[0] - x[j][0], dy = p[1] - x[j][1], dz = p[2] - x[j][2];
+        if (dx * dx + dy * dy + dz * dz <= coordcutsq) ncoord++;
+      }
+      if (ncoord < coord_kmin) continue;
+    }
+
+    if (occcut_flag) {
+      neigh.clear();
+      exclgrid.gather_neighborhood(p, neigh);
+      int veto = 0;
+      for (int j : neigh) {
+        double dx = p[0] - x[j][0], dy = p[1] - x[j][1], dz = p[2] - x[j][2];
+        if (dx * dx + dy * dy + dz * dz <= occcutsq) {
+          veto = 1;
+          break;
+        }
+      }
+      if (veto) continue;
+    }
+
+    double vol = 0.0;
+    if (volume_flag) {
+      voro::voronoicell pcell;
+      if (con.compute_ghost_cell(pcell, p[0], p[1], p[2])) vol = pcell.volume();
+      if (vol < vmin || vol > vmax) continue;
+    }
+
+    // a kept site whose clearance reaches the ghost shell may be affected by
+    // atoms this rank cannot see: tessellation no longer trustworthy
+
+    if (cr[c] > cutghost_min && !cutghost_warned && comm->me == 0) {
+      cutghost_warned = 1;
+      error->warning(FLERR,
+                     "Compute sites/voronoi found a site with clearance {:.4} exceeding the "
+                     "ghost cutoff {:.4}; increase comm_modify cutoff or tighten rmax",
+                     cr[c], cutghost_min);
+    }
+
+    if (nsites >= nsitesmax) {
+      nsitesmax += SITESDELTA;
+      memory->grow(sites, nsitesmax, size_local_cols, "sites/voronoi:sites");
+      array_local = sites;
+    }
+    sites[nsites][0] = p[0];
+    sites[nsites][1] = p[1];
+    sites[nsites][2] = p[2];
+    sites[nsites][3] = cr[c];
+    if (volume_flag) {
+      sites[nsites][4] = vol;
+      sites[nsites][5] = ncoord;
+    } else
+      sites[nsites][4] = ncoord;
+    nsites++;
+  }
+
+  size_local_rows = nsites;
+}
+
+/* ----------------------------------------------------------------------
+   global number of accepted sites across all processors
+------------------------------------------------------------------------- */
+
+double ComputeSitesVoronoi::compute_scalar()
+{
+  invoked_scalar = update->ntimestep;
+  if (invoked_local != update->ntimestep) compute_local();
+  double nlocalsites = size_local_rows;
+  MPI_Allreduce(&nlocalsites, &scalar, 1, MPI_DOUBLE, MPI_SUM, world);
+  return scalar;
+}
+
+/* ---------------------------------------------------------------------- */
+
+double ComputeSitesVoronoi::memory_usage()
+{
+  return (double) nsitesmax * size_local_cols * sizeof(double);
+}
