+ComputeSitesVoronoi::ComputeSitesVoronoi(LAMMPS *lmp, int narg, char **arg) :
+    Compute(lmp, narg, arg), idregion(nullptr), region(nullptr), rminstr(nullptr),
+    rmaxstr(nullptr), vminstr(nullptr), vmaxstr(nullptr), sites(nullptr)
+{
+  rmerge = -1.0;
+  rmin = 0.0;
+  rmax = BIGWINDOW;
+  vmin = 0.0;
+  vmax = BIGWINDOW;
+  volume_flag = 0;
+  coord_flag = 0;
+  coord_kmin = 0;
+  coord_rcut = 0.0;
+  hostgroupbit = groupbit;
+  occcut = 0.0;
+  occcut_flag = 0;
+  exclgroupbit = 0;
+  rminvar = rmaxvar = vminvar = vmaxvar = -1;
+  nsitesmax = 0;
+  cutghost_warned = 0;
+
+  int iarg = 3;
+  while (iarg < narg) {
+    if (strcmp(arg[iarg], "rmerge") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi rmerge", error);
+      rmerge = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      if (rmerge <= 0.0)
+        error->all(FLERR, "Compute sites/voronoi rmerge must be > 0.0, got {}", rmerge);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "rmin") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi rmin", error);
+      if (utils::strmatch(arg[iarg + 1], "^v_")) {
+        delete[] rminstr;
+        rminstr = utils::strdup(arg[iarg + 1] + 2);
+      } else
+        rmin = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "rmax") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi rmax", error);
+      if (utils::strmatch(arg[iarg + 1], "^v_")) {
+        delete[] rmaxstr;
+        rmaxstr = utils::strdup(arg[iarg + 1] + 2);
+      } else
+        rmax = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "vmin") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi vmin", error);
+      if (utils::strmatch(arg[iarg + 1], "^v_")) {
+        delete[] vminstr;
+        vminstr = utils::strdup(arg[iarg + 1] + 2);
+      } else
+        vmin = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      volume_flag = 1;
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "vmax") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi vmax", error);
+      if (utils::strmatch(arg[iarg + 1], "^v_")) {
+        delete[] vmaxstr;
+        vmaxstr = utils::strdup(arg[iarg + 1] + 2);
+      } else
+        vmax = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      volume_flag = 1;
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "metric") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi metric", error);
+      if (strcmp(arg[iarg + 1], "radius") == 0)
+        ;    // radius column is always present
+      else if (strcmp(arg[iarg + 1], "volume") == 0)
+        volume_flag = 1;
+      else
+        error->all(FLERR, "Unknown compute sites/voronoi metric: {}", arg[iarg + 1]);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "region") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi region", error);
+      delete[] idregion;
+      idregion = utils::strdup(arg[iarg + 1]);
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "coord") == 0) {
+      if (iarg + 3 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi coord", error);
+      coord_kmin = utils::inumeric(FLERR, arg[iarg + 1], false, lmp);
+      coord_rcut = utils::numeric(FLERR, arg[iarg + 2], false, lmp);
+      if (coord_kmin < 1 || coord_rcut <= 0.0)
+        error->all(FLERR, "Invalid compute sites/voronoi coord arguments: {} {}", coord_kmin,
+                   coord_rcut);
+      coord_flag = 1;
+      iarg += 3;
+    } else if (strcmp(arg[iarg], "hostgroup") == 0) {
+      if (iarg + 2 > narg)
+        utils::missing_cmd_args(FLERR, "compute sites/voronoi hostgroup", error);
+      int igroup = group->find(arg[iarg + 1]);
+      if (igroup < 0)
+        error->all(FLERR, "Compute sites/voronoi hostgroup {} does not exist", arg[iarg + 1]);
+      hostgroupbit = group->bitmask[igroup];
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "occcut") == 0) {
+      if (iarg + 2 > narg) utils::missing_cmd_args(FLERR, "compute sites/voronoi occcut", error);
+      occcut = utils::numeric(FLERR, arg[iarg + 1], false, lmp);
+      if (occcut <= 0.0)
+        error->all(FLERR, "Compute sites/voronoi occcut must be > 0.0, got {}", occcut);
+      occcut_flag = 1;
+      iarg += 2;
+    } else if (strcmp(arg[iarg], "exclgroup") == 0) {
+      if (iarg + 2 > narg)
+        utils::missing_cmd_args(FLERR, "compute sites/voronoi exclgroup", error);
+      int igroup = group->find(arg[iarg + 1]);
+      if (igroup < 0)
+        error->all(FLERR, "Compute sites/voronoi exclgroup {} does not exist", arg[iarg + 1]);
+      exclgroupbit = group->bitmask[igroup];
+      iarg += 2;
+    } else
+      error->all(FLERR, "Unknown compute sites/voronoi keyword: {}", arg[iarg]);
+  }
+
+  if (rmerge <= 0.0)
+    error->all(FLERR, "Compute sites/voronoi requires the rmerge keyword with a value > 0.0");
+  if (occcut_flag && !exclgroupbit)
+    error->all(FLERR, "Compute sites/voronoi occcut requires the exclgroup keyword");
+  if (exclgroupbit && !occcut_flag)
+    error->all(FLERR, "Compute sites/voronoi exclgroup requires the occcut keyword");
+
+  local_flag = 1;
+  size_local_rows = 0;
+  size_local_cols = volume_flag ? 6 : 5;    // x y z clearance [volume] coord
+
+  scalar_flag = 1;
+  extscalar = 0;
+}
