+static constexpr int SITESDELTA = 4096;         // grow chunk for the local site table
+static constexpr double BOUND_EPS = 0.01;       // container bound fudge (as compute voronoi/atom)
+static constexpr double BIGWINDOW = 1.0e30;     // "no upper bound" sentinel
+static constexpr int MAXBINS1D = 64;            // cap on clustering/criteria bin grid per dim
+static constexpr double MERGE_MARGIN = 4.0;     // collection halo, in units of rmerge
+static constexpr double OWN_NUDGE = 1.0e-9;     // relative ownership tie-break offset
+
+namespace {
+
+// simple cell-list over an axis-aligned box; bin size >= cutoff so a 27-bin
+// scan finds all neighbors within cutoff
+
+struct BinGrid {
+  double lo[3], inv[3];
+  int nb[3];
+  std::vector<std::vector<int>> bins;
+
+  void setup(const double *blo, const double *bhi, double cutoff)
+  {
+    for (int d = 0; d < 3; d++) {
+      lo[d] = blo[d];
+      double ext = bhi[d] - blo[d];
+      if (ext <= 0.0) ext = cutoff;
+      nb[d] = (int) (ext / cutoff);
+      if (nb[d] < 1) nb[d] = 1;
+      if (nb[d] > MAXBINS1D) nb[d] = MAXBINS1D;
+      inv[d] = nb[d] / ext;
+    }
+    bins.assign((std::size_t) nb[0] * nb[1] * nb[2], {});
+  }
+
+  int coord2bin(const double *p, int *ib) const
+  {
+    for (int d = 0; d < 3; d++) {
+      int i = (int) ((p[d] - lo[d]) * inv[d]);
+      if (i < 0) i = 0;
+      if (i >= nb[d]) i = nb[d] - 1;
+      ib[d] = i;
+    }
+    return (ib[2] * nb[1] + ib[1]) * nb[0] + ib[0];
+  }
+
+  void insert(const double *p, int idx)
+  {
+    int ib[3];
+    bins[coord2bin(p, ib)].push_back(idx);
+  }
+
+  // append indices of all entries in the 27 bins around p to out
+
+  void gather_neighborhood(const double *p, std::vector<int> &out) const
+  {
+    int ib[3];
+    coord2bin(p, ib);
+    for (int dz = -1; dz <= 1; dz++) {
+      int iz = ib[2] + dz;
+      if (iz < 0 || iz >= nb[2]) continue;
+      for (int dy = -1; dy <= 1; dy++) {
+        int iy = ib[1] + dy;
+        if (iy < 0 || iy >= nb[1]) continue;
+        for (int dx = -1; dx <= 1; dx++) {
+          int ix = ib[0] + dx;
+          if (ix < 0 || ix >= nb[0]) continue;
+          const std::vector<int> &b = bins[(std::size_t) (iz * nb[1] + iy) * nb[0] + ix];
+          out.insert(out.end(), b.begin(), b.end());
+        }
+      }
+    }
+  }
+};
+
+int uf_find(std::vector<int> &parent, int i)
+{
+  while (parent[i] != i) {
+    parent[i] = parent[parent[i]];
+    i = parent[i];
+  }
+  return i;
+}
+
+void uf_union(std::vector<int> &parent, int i, int j)
+{
+  int ri = uf_find(parent, i);
+  int rj = uf_find(parent, j);
+  if (ri != rj) parent[rj] = ri;
+}
